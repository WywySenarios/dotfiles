{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "scribe",
  "instructions": [
    "{file:/etc/Wywy-Website-Control/AGENTS.shared.md}"
  ],
  "agent": {
    "plan": {
      "disable": true
    }
  },
  "permission": {
    "edit": {
      "**/.opencode/plans/*": "deny",
      "**/.opencode/plan.md": "deny",
      "**/.opencode/Plan.md": "deny",
      "**/.opencode/PLAN.md": "deny"
    },
    "bash": {
      "/etc/Wywy-Website-Control/run.sh *": "allow",
      "/etc/Wywy-Website-Control/enter.sh *": "allow"
    },
    "external_directory": {
      "*": "deny",
      "/tmp/opencode/**": "allow",
      "/etc/Wywy-Website-Control/**": "allow",
      "/usr/local/Wywy-Website/**": "allow",
      "/var/log/Wywy-Website/**": "allow",
      "/var/lib/Wywy-Website/**": "allow",
      "/var/workspace/Wywy-Website/**": "allow",
      "{env:HOME}/src/**": "allow"
    },
    "read": {
      "**/.env": "allow",
      "**/.env.*": "allow"
    }
  }
}
