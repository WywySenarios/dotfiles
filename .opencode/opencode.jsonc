{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "scribe",
  "plugin": [
    "./plugins/opencode-rbash/src/index.ts"
  ],
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"]
    },
    "shfmt": {},
    "ruff": {},
    "gofmt": {},
    "rustfmt": {},
    "clang-format": {},
    "air": {}
  },
  "permission": {
    "edit": {
      "**/.opencode/plans/**": "deny",
      "**/.opencode/plan.md": "deny",
      "**/.opencode/Plan.md": "deny",
      "**/.opencode/PLAN.md": "deny"
    },
    "external_directory": {
      "*": "deny",
      "/tmp/opencode/**": "allow",
      "{env:HOME}/src/**": "allow",
      "{env:HOME}/plans/**": "allow"
    },
    "read": {
      "**/.env": "allow",
      "**/.env.*": "allow"
    }
  }
}
