{
  // Restricted bash configuration for the dotfiles project
  // Commands not in this allowlist will be rejected.
  // Executables listed here take precedence over script path patterns.
  "allow": {
    "ls": {},
    "echo": {},
    "cat": { "pipe_to": ["grep", "wc", "sort", "rg", "uniq"] },
    "git": {},
    "grep": {},
    "rg": {},
    "wc": {},
    "sort": {},
    "uniq": {},
    "mkdir": {},
    "rm": {},
    "cp": {},
    "mv": {},
    "touch": {},
    "chmod": {},
    "which": {},
    "type": {},
    "basename": {},
    "dirname": {},
    "readlink": {},
    "realpath": {},
    "stat": {},
    "id": {},
    "getent": {},
    "true": {},
    "false": {}
  },
  // Script path patterns — matched via glob against the command's first word.
  // Executables in "allow" take precedence if there is overlap.
  "scripts": ["scripts/**"],
  "script_interpreters": ["bash", "node", "python3", "npx", "npm"],
  "settings": {
    "timeout_ms": 120000,
    "workdir_policy": "project"
  }
}
